generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Column {
  id        String   @id @default(cuid())
  name      String
  order     Int
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("columns")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id])
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}
